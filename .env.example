# NanoClaw Configuration

# ============================================
# Required: Anthropic API Configuration
# ============================================

# Option 1: Anthropic API Key (recommended for production)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Option 2: OAuth Token (for Claude Code integration)
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
# or
# ANTHROPIC_AUTH_TOKEN=your-oauth-token

# Optional: Custom Anthropic API Base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================
# GitHub Models API (Free for Testing)
# ============================================
# GitHub offers free inference API for testing with OpenAI-compatible models
# Note: GitHub Models API uses OpenAI-compatible format, not Anthropic format
# To use GitHub Models:
# 1. Set ANTHROPIC_BASE_URL to GitHub Models endpoint
# 2. Set ANTHROPIC_API_KEY to your GitHub Personal Access Token
#
# ANTHROPIC_BASE_URL=https://models.inference.ai.azure.com
# ANTHROPIC_API_KEY=github_pat_...
#
# Available models: gpt-4o, gpt-4o-mini, and others
# See: https://github.com/marketplace/models

# ============================================
# Assistant Configuration
# ============================================

# Name of your assistant (used for trigger pattern @Name)
ASSISTANT_NAME=Andy

# Whether the assistant has its own phone number/identity
# ASSISTANT_HAS_OWN_NUMBER=false

# ============================================
# Server Ports
# ============================================

# Credential proxy port (for container API requests)
CREDENTIAL_PROXY_PORT=3001

# Web dialog channel port (web-based chat interface)
WEB_DIALOG_PORT=3002

# ============================================
# Container Configuration
# ============================================

# Container image name
# CONTAINER_IMAGE=nanoclaw-agent:latest

# Container timeout in milliseconds (default: 30 minutes)
# CONTAINER_TIMEOUT=1800000

# Maximum container output size in bytes (default: 10MB)
# CONTAINER_MAX_OUTPUT_SIZE=10485760

# Idle timeout in milliseconds (default: 30 minutes)
# IDLE_TIMEOUT=1800000

# Maximum number of concurrent containers
# MAX_CONCURRENT_CONTAINERS=5

# ============================================
# Timezone
# ============================================

# Timezone for scheduled tasks (uses system timezone by default)
# TZ=America/New_York
